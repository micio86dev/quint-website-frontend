---
interface Props {
  eyebrow: string;
  title: string;
  body: string;
  action: string;
  href: string;
}

const { eyebrow, title, body, action, href } = Astro.props;
---

<section
  class="flex flex-col items-start gap-10 mx-5 mb-[clamp(4rem,8vw,7rem)] px-[clamp(1.25rem,5vw,5rem)] py-[clamp(2.5rem,6vw,5rem)] rounded-2xl bg-violet text-white md:flex-row md:items-end md:justify-between md:mx-auto md:max-w-[1200px]"
  aria-labelledby="cta-title"
  data-reveal
>
  <div>
    <p class="eyebrow text-inherit opacity-75">{eyebrow}</p>
    <h2 id="cta-title" class="m-0 max-w-[13ch] font-extrabold tracking-[-0.06em] text-[clamp(2.1rem,4vw,4rem)] leading-[1.08]">{title}</h2>
    <p class="max-w-[53ch] mt-4 mb-0 text-inherit opacity-[0.78]">{body}</p>
  </div>
  <a class="btn btn-light" href={href}>{action}<span aria-hidden="true">→</span></a>
</section>
