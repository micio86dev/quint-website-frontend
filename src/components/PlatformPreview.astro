---
import type { HomeCopy, Locale } from '../content/site';

const { copy, locale } = Astro.props as { copy: HomeCopy['hero']; locale: Locale };
const signals = copy.platformSignals.slice(0, 4);
const isIT = locale === 'it';

const ui = {
  pipeline:   isIT ? 'Pipeline' : 'Pipeline',
  screened:   isIT ? 'Selezionati' : 'Screened',
  interview:  isIT ? 'Colloquio AI' : 'AI Interview',
  qualified:  isIT ? 'Idonei' : 'Qualified',
  scores:     isIT ? 'Punteggi' : 'Scores',
  topLabel:   isIT ? 'Top candidato' : 'Top candidate',
  live:       isIT ? 'Colloquio live' : 'Live interview',
  progress:   isIT ? 'completato' : 'completed',
  metrics:    isIT ? 'Metriche chiave' : 'Key metrics',
  slides:     isIT ? 'Schermate' : 'Screens',
};

const slideNames = [ui.pipeline, ui.scores, ui.live, ui.metrics];
const totalSlides = signals.length > 0 ? 4 : 3;
const railLabels = slideNames.slice(0, totalSlides);
---

<section class="platform-preview" aria-labelledby="platform-preview-title" data-reveal>
  <header class="platform-preview__header">
    <span class="platform-preview__brand">{copy.platformLabel}</span>
    <span class="platform-preview__status"><i aria-hidden="true"></i>{copy.platformStatus}</span>
  </header>
  <div class="platform-preview__body">
    <div class="platform-preview__rail" role="group" aria-label={ui.slides}>
      {railLabels.map((label, i) => (
        <button
          class="beai-rail-check"
          data-index={i}
          type="button"
          aria-current={i === 0 ? 'true' : 'false'}
          aria-label={label}
        >
          <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 6.2 5 8.5 9.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      ))}
    </div>
    <div class="platform-preview__workspace">

      <div class="platform-preview__intro">
        <p class="eyebrow">BEAI / 01</p>
        <h2 id="platform-preview-title">{copy.platformTitle}</h2>
        <p>{copy.platformDescription}</p>
      </div>

      <!-- Slides wrapper -->
      <div class="beai-slides-wrap" id="beai-slides">

        <!-- ── Slide 1: Pipeline kanban ── -->
        <div class="beai-slide" data-active="true">
          <p class="beai-slide__tag">{ui.pipeline}</p>
          <div class="beai-pipeline">
            <div class="beai-stage">
              <div class="beai-stage__head">
                <span class="beai-stage__label">{ui.screened}</span>
                <span class="beai-stage__count">24</span>
              </div>
              <div class="beai-candidate"></div>
              <div class="beai-candidate"></div>
              <div class="beai-candidate beai-candidate--active"></div>
            </div>
            <div class="beai-stage">
              <div class="beai-stage__head">
                <span class="beai-stage__label">{ui.interview}</span>
                <span class="beai-stage__count">12</span>
              </div>
              <div class="beai-candidate"></div>
              <div class="beai-candidate beai-candidate--active"></div>
              <div class="beai-candidate"></div>
            </div>
            <div class="beai-stage">
              <div class="beai-stage__head">
                <span class="beai-stage__label">{ui.qualified}</span>
                <span class="beai-stage__count">3</span>
              </div>
              <div class="beai-candidate beai-candidate--top"></div>
              <div class="beai-candidate"></div>
            </div>
          </div>
          <!-- Score bar at bottom of pipeline -->
          <div class="beai-score-strip">
            <span class="beai-score-strip__label">{ui.topLabel}</span>
            <div class="beai-score-strip__bar">
              <div class="beai-score-strip__fill w-[94%]"></div>
            </div>
            <span class="beai-score-strip__val">94</span>
          </div>
        </div>

        <!-- ── Slide 2: Candidate ranking ── -->
        <div class="beai-slide" data-active="false">
          <p class="beai-slide__tag">{ui.scores}</p>
          <div class="beai-ranking">
            <div class="beai-rank-row beai-rank-row--gold">
              <span class="beai-rank-pos">1</span>
              <div class="beai-rank-bar"><div class="beai-rank-fill w-[94%]"></div></div>
              <span class="beai-rank-val">94</span>
            </div>
            <div class="beai-rank-row">
              <span class="beai-rank-pos">2</span>
              <div class="beai-rank-bar"><div class="beai-rank-fill w-[87%]"></div></div>
              <span class="beai-rank-val">87</span>
            </div>
            <div class="beai-rank-row">
              <span class="beai-rank-pos">3</span>
              <div class="beai-rank-bar"><div class="beai-rank-fill beai-rank-fill--mid w-[71%]"></div></div>
              <span class="beai-rank-val beai-rank-val--mid">71</span>
            </div>
            <div class="beai-rank-row">
              <span class="beai-rank-pos">4</span>
              <div class="beai-rank-bar"><div class="beai-rank-fill beai-rank-fill--low w-[58%]"></div></div>
              <span class="beai-rank-val beai-rank-val--low">58</span>
            </div>
          </div>
        </div>

        <!-- ── Slide 3: Live AI interview ── -->
        <div class="beai-slide" data-active="false">
          <p class="beai-slide__tag">{ui.live}</p>
          <div class="beai-interview-view">
            <div class="beai-avatar" aria-hidden="true">
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                <circle cx="18" cy="18" r="18" fill="rgba(119,26,175,.12)"/>
                <circle cx="18" cy="14" r="6" fill="var(--violet)"/>
                <path d="M7 33c0-6.07 4.93-11 11-11s11 4.93 11 11" stroke="var(--violet)" stroke-width="2.2" fill="none" stroke-linecap="round"/>
              </svg>
              <span class="beai-live-dot" aria-hidden="true"></span>
            </div>
            <div class="beai-interview-meta">
              <p class="beai-interview-name">Candidato #8</p>
              <p class="beai-interview-step">Domanda 4 / 6</p>
            </div>
            <div class="beai-progress-wrap">
              <div class="beai-progress-bar">
                <div class="beai-progress-fill w-[67%]"></div>
              </div>
              <span class="beai-progress-label">67% {ui.progress}</span>
            </div>
            <div class="beai-waveform" aria-hidden="true">
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span>
            </div>
          </div>
        </div>

        <!-- ── Slide 4: Key metrics (dynamic) ── -->
        {signals.length > 0 && (
          <div class="beai-slide" data-active="false">
            <p class="beai-slide__tag">{ui.metrics}</p>
            <div class="beai-metrics-grid">
              {signals.map(s => (
                <div class="beai-metric-card">
                  <span class="beai-metric-val">{s.value}</span>
                  <span class="beai-metric-lbl">{s.label}</span>
                </div>
              ))}
            </div>
          </div>
        )}

      </div><!-- /beai-slides-wrap -->

    </div><!-- /workspace -->
  </div>
</section>

<script>
  // @ts-nocheck — vanilla DOM runtime script (was is:inline, now bundled so
  // Astro can hash it for CSP); not part of the type-checked app surface.
  (function () {
    const wrap = document.getElementById('beai-slides');
    if (!wrap) return;
    const section = wrap.closest('.platform-preview');
    const slides = wrap.querySelectorAll('.beai-slide');
    const checks = section ? section.querySelectorAll('.beai-rail-check') : [];
    if (!slides.length) return;

    let cur = 0;
    let timer = null;

    function goTo(idx) {
      slides[cur].dataset.active = 'false';
      checks[cur] && checks[cur].setAttribute('aria-current', 'false');
      cur = ((idx % slides.length) + slides.length) % slides.length;
      slides[cur].dataset.active = 'true';
      checks[cur] && checks[cur].setAttribute('aria-current', 'true');
    }

    function start() { timer = setInterval(function () { goTo(cur + 1); }, 4500); }
    function stop()  { if (timer) { clearInterval(timer); timer = null; } }

    checks.forEach(function (c, i) {
      c.addEventListener('click', function () { stop(); goTo(i); start(); });
    });

    section && section.addEventListener('mouseenter', stop);
    section && section.addEventListener('mouseleave', start);

    start();
  })();
</script>

<style>
  /* ── Shell / frame (was global.css .platform-preview*) ── */
  .platform-preview {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 18px;
    background: #fff;
    box-shadow: var(--shadow-quint);
  }

  .platform-preview::before {
    position: absolute;
    top: -9rem;
    right: -9rem;
    width: 17rem;
    height: 17rem;
    border: 1px solid rgb(119 26 175 / 20%);
    border-radius: 50%;
    content: '';
  }

  .platform-preview__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 58px;
    padding: 0 1.25rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-ink);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .platform-preview__brand {
    color: var(--color-violet);
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .platform-preview__status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-muted);
    font-size: 0.68rem;
  }

  .platform-preview__status i {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-orange);
  }

  .platform-preview__body {
    display: grid;
    grid-template-columns: 58px minmax(0, 1fr);
    min-height: 455px;
  }

  .platform-preview__rail {
    display: grid;
    align-content: start;
    justify-items: center;
    gap: 1rem;
    padding-top: 1.25rem;
    background: var(--color-violet);
  }

  .beai-rail-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    padding: 0;
    background: transparent;
    border: 1px solid rgb(255 255 255 / 55%);
    border-radius: 5px;
    color: transparent;
    cursor: pointer;
    box-shadow: none;
    transition: background 220ms var(--ease-quint), border-color 220ms, color 220ms, transform 220ms;
  }

  .beai-rail-check svg { width: 12px; height: 12px; }
  .beai-rail-check:hover { border-color: #fff; }
  .beai-rail-check[aria-current="true"] {
    background: var(--color-orange);
    border-color: var(--color-orange);
    color: #fff;
  }

  .platform-preview__workspace {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    align-content: start;
    padding: 1.65rem;
    background: #fff;
  }

  .platform-preview__intro { grid-column: 1 / -1; }
  .platform-preview__intro .eyebrow { margin-bottom: 0.45rem; font-size: 0.65rem; }
  .platform-preview__intro h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.2vw, 1.85rem);
    letter-spacing: -0.045em;
    line-height: 1.15;
  }
  .platform-preview__intro > p:last-child {
    margin: 0.45rem 0 0;
    color: var(--color-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 900px) {
    .platform-preview { width: min(100%, 650px); margin-inline: auto; }
  }

  @media (max-width: 760px) {
    .platform-preview__body { grid-template-columns: 42px minmax(0, 1fr); min-height: 420px; }
    .platform-preview__workspace { padding: 1.1rem; }
  }

  /* ── Slides wrapper ── */
  .beai-slides-wrap {
    grid-column: 1 / -1;
    position: relative;
    height: 155px;
    overflow: hidden;
  }

  .beai-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 550ms ease;
    pointer-events: none;
  }

  .beai-slide[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  .beai-slide__tag {
    font-size: .6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
    margin: 0 0 .55rem;
  }

  /* ── Slide 1: Pipeline ── */
  .beai-pipeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .5rem;
  }

  .beai-stage {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    padding: .6rem .55rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }

  .beai-stage__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: .1rem;
  }

  .beai-stage__label {
    font-size: .55rem;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  .beai-stage__count {
    font-size: 1rem;
    font-weight: 800;
    color: var(--violet);
    letter-spacing: -.04em;
  }

  .beai-candidate {
    height: 7px;
    border-radius: 3px;
    background: var(--line);
  }

  .beai-candidate--active { background: rgba(119,26,175,.35); }
  .beai-candidate--top    { background: var(--orange); }

  .beai-score-strip {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-top: .55rem;
    padding: .55rem .75rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }

  .beai-score-strip__label {
    font-size: .62rem;
    font-weight: 700;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .beai-score-strip__bar {
    flex: 1;
    height: 5px;
    border-radius: 3px;
    background: var(--line);
    overflow: hidden;
  }

  .beai-score-strip__fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--violet), var(--orange));
  }

  .beai-score-strip__val {
    font-size: .95rem;
    font-weight: 800;
    color: var(--violet);
    flex-shrink: 0;
  }

  /* ── Slide 2: Ranking ── */
  .beai-ranking {
    display: flex;
    flex-direction: column;
    gap: .45rem;
  }

  .beai-rank-row {
    display: flex;
    align-items: center;
    gap: .55rem;
  }

  .beai-rank-pos {
    font-size: .65rem;
    font-weight: 800;
    color: var(--muted);
    width: 14px;
    flex-shrink: 0;
    text-align: right;
  }

  .beai-rank-row--gold .beai-rank-pos { color: var(--orange); }

  .beai-rank-bar {
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: var(--line);
    overflow: hidden;
  }

  .beai-rank-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--violet), var(--orange));
  }

  .beai-rank-fill--mid { background: linear-gradient(90deg, var(--violet), rgba(119,26,175,.4)); }
  .beai-rank-fill--low { background: var(--line); filter: brightness(.8); }

  .beai-rank-val {
    font-size: .75rem;
    font-weight: 800;
    color: var(--violet);
    width: 20px;
    flex-shrink: 0;
    text-align: right;
  }

  .beai-rank-val--mid { color: var(--muted); }
  .beai-rank-val--low { color: var(--muted); opacity: .6; }

  /* ── Slide 3: Live interview ── */
  .beai-interview-view {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }

  .beai-avatar {
    position: relative;
    display: inline-flex;
    width: 36px;
  }

  .beai-live-dot {
    position: absolute;
    bottom: 1px;
    right: 1px;
    width: 9px;
    height: 9px;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid var(--paper);
    animation: pulse-dot 1.6s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: .4; }
  }

  .beai-interview-meta {
    display: flex;
    align-items: baseline;
    gap: .75rem;
  }

  .beai-interview-name {
    font-size: .85rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }

  .beai-interview-step {
    font-size: .72rem;
    color: var(--muted);
    font-weight: 600;
    margin: 0;
  }

  .beai-progress-wrap {
    display: flex;
    align-items: center;
    gap: .65rem;
  }

  .beai-progress-bar {
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: var(--line);
    overflow: hidden;
  }

  .beai-progress-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--violet), var(--orange));
  }

  .beai-progress-label {
    font-size: .68rem;
    color: var(--muted);
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .beai-waveform {
    display: flex;
    align-items: center;
    gap: 3px;
    height: 22px;
  }

  .beai-waveform span {
    display: block;
    width: 3px;
    border-radius: 2px;
    background: var(--violet);
    animation: wave 1.1s ease-in-out infinite;
  }

  .beai-waveform span:nth-child(1) { height: 6px;  animation-delay:  .0s; }
  .beai-waveform span:nth-child(2) { height: 14px; animation-delay: .1s; }
  .beai-waveform span:nth-child(3) { height: 20px; animation-delay: .2s; }
  .beai-waveform span:nth-child(4) { height: 12px; animation-delay: .3s; }
  .beai-waveform span:nth-child(5) { height: 18px; animation-delay: .4s; }
  .beai-waveform span:nth-child(6) { height: 8px;  animation-delay: .5s; }
  .beai-waveform span:nth-child(7) { height: 4px;  animation-delay: .6s; }

  @keyframes wave {
    0%, 100% { transform: scaleY(1); opacity: .7; }
    50% { transform: scaleY(1.8); opacity: 1; }
  }

  /* ── Slide 4: Metrics grid ── */
  .beai-metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .5rem;
  }

  .beai-metric-card {
    display: flex;
    flex-direction: column;
    gap: .15rem;
    padding: .55rem .65rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }

  .beai-metric-val {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--violet);
    letter-spacing: -.04em;
    line-height: 1;
  }

  .beai-metric-lbl {
    font-size: .62rem;
    color: var(--muted);
    font-weight: 600;
    line-height: 1.3;
  }
</style>
