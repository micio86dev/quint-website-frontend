---
import type { HomeCopy } from '../content/site';

const { eyebrow, items, title } = Astro.props as { eyebrow: string; items: HomeCopy['faq']; title: string };
---

<section class="home-section faq-section" aria-labelledby="faq-title">
  <div class="section-heading">
    <p class="eyebrow">{eyebrow}</p>
    <h2 id="faq-title">{title}</h2>
  </div>
  <div class="faq-list">
    {items.map((item, index) => <details open={index === 0}><summary>{item.question}<span aria-hidden="true">+</span></summary><p>{item.answer}</p></details>)}
  </div>
</section>
