---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CapabilityHighlights from '../../components/CapabilityHighlights.astro';
import CtaBlock from '../../components/CtaBlock.astro';
import Faq from '../../components/Faq.astro';
import HomeHero from '../../components/HomeHero.astro';
import ProductShowcase from '../../components/ProductShowcase.astro';
import StatisticsBand from '../../components/StatisticsBand.astro';
import { getLocale, getProducts, locales, localizedPath, siteCopy } from '../../content/site';
export function getStaticPaths() { return locales.map((locale) => ({ params: { locale } })); }
const locale = getLocale(Astro.params.locale);
const copy = siteCopy[locale];
const products = getProducts(locale);
---
<BaseLayout locale={locale} title="Quint" description={copy.brandStatement}>
  <HomeHero
    copy={copy.home.hero}
    locale={locale}
    primaryAction={{ href: localizedPath(locale, 'contact'), label: copy.cta }}
    secondaryAction={{ href: localizedPath(locale, 'products'), label: copy.secondaryCta }}
  />
  <StatisticsBand statistics={copy.home.statistics} label={copy.home.hero.platformLabel} />
  <ProductShowcase copy={copy.home.product} products={products.slice(0, 3)} locale={locale} allProductsHref={localizedPath(locale, 'products')} />
  <CapabilityHighlights copy={copy.home.capabilities} />
  <Faq eyebrow={copy.home.faqHeading.eyebrow} items={copy.home.faq} title={copy.home.faqHeading.title} />
  <CtaBlock copy={copy.home.finalCta} href={localizedPath(locale, 'contact')} />
</BaseLayout>
