---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import { getLocale, locales, localizedPath } from '../../../../content/site';
import { getSiteText, getProducts } from '../../../../lib/content';
import type { Locale } from '../../../../content/site';

export function getStaticPaths() {
  return locales.flatMap((locale: Locale) =>
    ['diagnostics', 'research', 'quality'].map((family) => ({ params: { locale, family } }))
  );
}

const locale = getLocale(Astro.params.locale);
const family = Astro.params.family as 'diagnostics' | 'research' | 'quality';

if (!['diagnostics', 'research', 'quality'].includes(family)) {
  return Astro.redirect(localizedPath(locale, 'products'));
}

const [t, allProducts] = await Promise.all([getSiteText(locale), getProducts(locale)]);
const products = allProducts.filter((p) => p.family === family);
const familyTitle = t[`families.${family}.title`];
const familyDescription = t[`families.${family}.description`];
---

<BaseLayout
  locale={locale}
  path={`products/${family}`}
  title={familyTitle}
  description={familyDescription}
>
  <section class="max-w-[1200px] mx-auto px-[clamp(1.25rem,4vw,3rem)] pt-[clamp(4.5rem,10vw,8rem)] pb-[clamp(3.5rem,8vw,6rem)] border-b border-line" data-reveal>
    <p class="eyebrow">QUINT / {t['nav.products']}</p>
    <h1 class="m-0 max-w-[13ch] font-extrabold tracking-[-0.06em] text-[clamp(2.8rem,5.2vw,4.75rem)] leading-[1.03]">{familyTitle}</h1>
    <p class="max-w-[57ch] mt-6 text-muted text-[clamp(1.06rem,1.5vw,1.22rem)]">{familyDescription}</p>
  </section>
  <section class="max-w-[1200px] mx-auto px-[clamp(1.25rem,4vw,3rem)] py-[clamp(4.8rem,9vw,8rem)]">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3" data-reveal-stagger>
      {products.map((product) => (
        <ProductCard
          product={product}
          locale={locale}
          familyTitle={familyTitle}
          learnMore={t['learnMore']}
        />
      ))}
    </div>
  </section>
</BaseLayout>
