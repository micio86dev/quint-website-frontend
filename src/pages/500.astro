---
import BaseLayout from '../layouts/BaseLayout.astro';

// Shown on unexpected server errors. Locale-neutral, like 404: the CTA points at
// "/", where the client router forwards the visitor to their language home.
---
<BaseLayout locale="it" title="500" description="Errore del server — Quint" path="">
  <section class="error-page" aria-labelledby="error-title">
    <p class="error-code" aria-hidden="true">500</p>
    <p class="eyebrow text-orange-deep">Errore 500</p>
    <h1 id="error-title">Qualcosa è andato storto</h1>
    <p class="error-lead">
      Si è verificato un errore imprevisto. Riprova tra qualche istante.
      <span lang="en">Something went wrong on our side. Please try again in a moment.</span>
    </p>
    <a class="btn btn-primary" href="/">Torna alla homepage<span aria-hidden="true">→</span></a>
  </section>

  <style>
    .error-page {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
      max-width: 1200px;
      margin-inline: auto;
      padding: clamp(4rem, 12vw, 9rem) clamp(1.25rem, 4vw, 3rem) clamp(5rem, 14vw, 10rem);
    }
    .error-code {
      margin: 0;
      font-size: clamp(6rem, 22vw, 16rem);
      font-weight: 800;
      line-height: 0.9;
      letter-spacing: -0.06em;
      background: linear-gradient(120deg, var(--color-violet), var(--color-orange));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .error-page .eyebrow { margin-top: 0.5rem; }
    .error-page h1 {
      margin: 0.25rem 0 0;
      max-width: 18ch;
      font-size: clamp(2rem, 4vw, 3.25rem);
      font-weight: 800;
      letter-spacing: -0.045em;
      line-height: 1.1;
    }
    .error-lead {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      max-width: 52ch;
      margin: 1.1rem 0 2rem;
      color: var(--color-muted);
      font-size: clamp(1rem, 1.5vw, 1.15rem);
      line-height: 1.6;
    }
    .error-lead span[lang="en"] { color: var(--color-muted); opacity: 0.72; font-size: 0.92em; }
  </style>
</BaseLayout>
